digraph AnalisadorLexico {
    // Configurações gerais
    rankdir = LR;
    node [shape = circle, style = filled, fillcolor = "#ffffff", fontsize = 14];
    edge [fontsize = 12];

    // Nó de entrada (seta vazia)
    inicio [label="", shape=none, width=0, height=0];
    
    // Definição dos nós de aceitação (círculo duplo)
    node [shape = doublecircle];
    q0;q1; q2; q4; q5; q6; q7;

    // Nós normais
    node [shape = circle];
    q0; q3; q8;

    // Transições iniciais
    inicio -> q0;

    // q0 e seus desvios (Léxico)
    q0 -> q0 [label = ";\n /\n -\n ,\n +\n *\n )\n (\n",headlabel="", distance=3, angle=60, tailport=nnw, headport=nn];
    q0 -> q1 [label = "A-Z"];
    q0 -> q2 [label = "0-9"];
    q0 -> q5 [label = ":"];
    q0 -> q6 [label = "<"];
    q0 -> q7 [label = ">"];
    q0 -> q8 [label = "{"];
    q8 -> q0 [label = "}"];

    // Loops e caminhos específicos
    q1 -> q1 [label = "A\n1"];
    q2 -> q2 [label = "0-9"];
    q2 -> q3 [label = "."];
    q3 -> q4 [label = "0-9"];
    q4 -> q4 [label = "0-9"];
    
    q5 -> q5 [label = "="];
    q6 -> q6 [label = ">\n="];
    
    q8 -> q8 [label = "~\n}"];

    // Título do gráfico
    label = "Autômato Analisador Léxico";
    fontsize = 20;
    labelloc = "t";
}